<Project>

  <PropertyGroup>
    <!--
      These defaults are used when NOT using [ModInfo] auto-setup.
      When [ModInfo] is present, the SetupFabricTemplate task overrides
      CSCraftPackageName and CSCraftFabricPath automatically.

      Manual override: set these in your .csproj to configure the transpiler:
        <CSCraftPackageName>com.yourname.mymod</CSCraftPackageName>
        <CSCraftFabricPath>C:\path\to\FabricTemplate</CSCraftFabricPath>
    -->
    <CSCraftPackageName Condition="'$(CSCraftPackageName)' == ''"></CSCraftPackageName>
    <CSCraftRunGradle   Condition="'$(CSCraftRunGradle)'   == ''">true</CSCraftRunGradle>
    <CSCraftJavaHome    Condition="'$(CSCraftJavaHome)'    == ''"></CSCraftJavaHome>
    <CSCraftFabricPath  Condition="'$(CSCraftFabricPath)'  == ''">$(MSBuildProjectDirectory)\FabricTemplate</CSCraftFabricPath>

    <!-- Path to the bundled Gradle wrapper in the NuGet package -->
    <_CSCraftGradleWrapperDir>$(MSBuildThisFileDirectory)gradle-wrapper/</_CSCraftGradleWrapperDir>
  </PropertyGroup>

</Project>
