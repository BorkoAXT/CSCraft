<Project>

  <!-- Register MSBuild tasks from the DLLs bundled in this package -->
  <UsingTask
    TaskName="BuildTask.TranspileMod"
    AssemblyFile="$(MSBuildThisFileDirectory)tasks/BuildTask.dll" />

  <UsingTask
    TaskName="BuildTask.SetupFabricTemplate"
    AssemblyFile="$(MSBuildThisFileDirectory)tasks/BuildTask.dll" />

  <!--
    ═══════════════════════════════════════════════════════════════════════════
    Single unified target: Setup → Transpile → Gradle

    All three steps run in one target to avoid MSBuild condition-evaluation
    race conditions (target Condition is evaluated BEFORE DependsOnTargets).
    No Inputs/Outputs — runs on every build so changes are always picked up.
    ═══════════════════════════════════════════════════════════════════════════
  -->
  <Target Name="CSCraftBuild" BeforeTargets="CoreCompile">

    <!-- ── Step 1: Setup ── Scan for [ModInfo], generate FabricTemplate ──── -->

    <ItemGroup>
      <_CSCraftSources Include="@(Compile)"
        Exclude="$(IntermediateOutputPath)**;**/*.g.cs;**/*.AssemblyInfo.cs" />
    </ItemGroup>

    <SetupFabricTemplate
      SourceFiles="@(_CSCraftSources)"
      ProjectDirectory="$(MSBuildProjectDirectory)"
      GradleWrapperSourceDir="$(_CSCraftGradleWrapperDir)"
      ManualJavaHome="$(CSCraftJavaHome)">

      <Output TaskParameter="FabricTemplatePath"  PropertyName="_CSCraftAutoFabricPath" />
      <Output TaskParameter="PackageName"         PropertyName="_CSCraftAutoPackageName" />
      <Output TaskParameter="ModId"               PropertyName="_CSCraftAutoModId" />
      <Output TaskParameter="ModInfoFound"        PropertyName="_CSCraftModInfoFound" />
      <Output TaskParameter="DiscoveredJavaHome"  PropertyName="_CSCraftDiscoveredJava" />
    </SetupFabricTemplate>

    <!-- Apply ModInfo outputs -->
    <PropertyGroup Condition="'$(_CSCraftModInfoFound)' == 'True'">
      <CSCraftFabricPath    Condition="'$(CSCraftFabricPath)' == ''">$(_CSCraftAutoFabricPath)</CSCraftFabricPath>
      <CSCraftPackageName   Condition="'$(CSCraftPackageName)' == ''">$(_CSCraftAutoPackageName)</CSCraftPackageName>
    </PropertyGroup>

    <!-- Use discovered JDK if the user didn't set one manually -->
    <PropertyGroup Condition="'$(CSCraftJavaHome)' == '' and '$(_CSCraftDiscoveredJava)' != ''">
      <CSCraftJavaHome>$(_CSCraftDiscoveredJava)</CSCraftJavaHome>
    </PropertyGroup>

    <!-- Fallback defaults -->
    <PropertyGroup>
      <CSCraftFabricPath    Condition="'$(CSCraftFabricPath)' == ''">$(MSBuildProjectDirectory)\FabricTemplate</CSCraftFabricPath>
      <CSCraftResourcesPath Condition="'$(CSCraftResourcesPath)' == ''">$(CSCraftFabricPath)\src\main\resources</CSCraftResourcesPath>
    </PropertyGroup>

    <!-- ── Step 1b: Copy user assets (textures, sounds) ───────────────── -->

    <ItemGroup>
      <_CSCraftAssets Include="$(MSBuildProjectDirectory)\Assets\**\*"
                      Condition="Exists('$(MSBuildProjectDirectory)\Assets')" />
    </ItemGroup>

    <PropertyGroup>
      <_CSCraftAssetsTarget>$(CSCraftResourcesPath)\assets\$(_CSCraftAutoModId)</_CSCraftAssetsTarget>
    </PropertyGroup>

    <Copy SourceFiles="@(_CSCraftAssets)"
          DestinationFiles="@(_CSCraftAssets->'$(_CSCraftAssetsTarget)\%(RecursiveDir)%(Filename)%(Extension)')"
          Condition="'@(_CSCraftAssets)' != ''" SkipUnchangedFiles="true" />

    <Message Condition="'@(_CSCraftAssets)' != ''"
             Importance="High" Text="CSCraft: Copied %(RecursiveDir)%(Filename)%(Extension) → assets/$(_CSCraftAutoModId)/%(RecursiveDir)%(Filename)%(Extension)" />

    <!-- ── Step 2: Transpile ── Convert C# to Java ──────────────────────── -->

    <Error Condition="'$(CSCraftPackageName)' == ''"
           Text="CSCraft: No package name found. Either add [ModInfo(Id=&quot;mymod&quot;, Name=&quot;My Mod&quot;)] to your mod class, or set &lt;CSCraftPackageName&gt; in your .csproj." />

    <!-- Resolve the Java output directory dynamically from the package name -->
    <PropertyGroup>
      <_PackageFolder>$(CSCraftPackageName.Replace('.', '\'))</_PackageFolder>
      <CSCraftOutputDir>$(CSCraftFabricPath)\src\main\java\$(_PackageFolder)</CSCraftOutputDir>
    </PropertyGroup>

    <!-- Ensure the output directory exists before writing .java files -->
    <MakeDir Directories="$(CSCraftOutputDir)" />

    <Message Text="CSCraft: transpiling %(_CSCraftSources.Filename)%(_CSCraftSources.Extension)"
             Importance="High" Condition="'@(_CSCraftSources)' != ''" />

    <TranspileMod
      SourceFiles="@(_CSCraftSources)"
      OutputDirectory="$(CSCraftOutputDir)"
      PackageName="$(CSCraftPackageName)"
      ResourcesDirectory="$(CSCraftResourcesPath)" />

    <Message Text="CSCraft: Java written to $(CSCraftOutputDir)" Importance="High" />

    <!-- ── Step 3: Gradle ── Build the mod JAR ──────────────────────────── -->

    <Error Condition="'$(CSCraftRunGradle)' == 'true' and '$(CSCraftJavaHome)' == ''"
           Text="CSCraft: Could not find a suitable JDK (17 or 21). Please install a JDK from https://adoptium.net/ or set &lt;CSCraftJavaHome&gt; in your .csproj." />

    <Message Condition="'$(CSCraftRunGradle)' == 'true'"
             Importance="High" Text="CSCraft: Using JDK at $(CSCraftJavaHome)" />
    <Message Condition="'$(CSCraftRunGradle)' == 'true'"
             Importance="High" Text="CSCraft: Starting Fabric Gradle build (generating JAR)..." />

    <!-- Windows -->
    <Exec Condition="'$(CSCraftRunGradle)' == 'true' and $([MSBuild]::IsOSPlatform('Windows')) and Exists('$(CSCraftFabricPath)\gradlew.bat')"
          Command="set &quot;JAVA_HOME=$(CSCraftJavaHome)&quot; &amp;&amp; &quot;$(CSCraftFabricPath)\gradlew.bat&quot; build"
          WorkingDirectory="$(CSCraftFabricPath)" />

    <!-- Linux / macOS -->
    <Exec Condition="'$(CSCraftRunGradle)' == 'true' and !$([MSBuild]::IsOSPlatform('Windows')) and Exists('$(CSCraftFabricPath)/gradlew')"
          Command="export JAVA_HOME=&quot;$(CSCraftJavaHome)&quot; &amp;&amp; chmod +x &quot;$(CSCraftFabricPath)/gradlew&quot; &amp;&amp; &quot;$(CSCraftFabricPath)/gradlew&quot; build"
          WorkingDirectory="$(CSCraftFabricPath)" />

    <!-- ── Step 4: Copy JAR to project folder ─────────────────────────── -->

    <ItemGroup Condition="'$(CSCraftRunGradle)' == 'true'">
      <_CSCraftJars Include="$(CSCraftFabricPath)\build\libs\*.jar"
                    Exclude="$(CSCraftFabricPath)\build\libs\*-sources.jar;$(CSCraftFabricPath)\build\libs\*-dev.jar" />
    </ItemGroup>

    <Copy SourceFiles="@(_CSCraftJars)"
          DestinationFolder="$(MSBuildProjectDirectory)"
          Condition="'$(CSCraftRunGradle)' == 'true' and '@(_CSCraftJars)' != ''"
          SkipUnchangedFiles="false" />

    <Message Condition="'$(CSCraftRunGradle)' == 'true'" Importance="High" Text=" " />
    <Message Condition="'$(CSCraftRunGradle)' == 'true'" Importance="High" Text="----------------------------------------------------------" />
    <Message Condition="'$(CSCraftRunGradle)' == 'true'" Importance="High" Text="SUCCESS: Mod JAR copied to $(MSBuildProjectDirectory)" />
    <Message Condition="'$(CSCraftRunGradle)' == 'true'" Importance="High" Text="----------------------------------------------------------" />
    <Message Condition="'$(CSCraftRunGradle)' == 'true'" Importance="High" Text=" " />

  </Target>

</Project>
