<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package identity -->
    <PackageId>CSCraft.Sdk</PackageId>
    <Version>1.4.1</Version>

    <!-- NuGet listing metadata -->
    <Title>CSCraft SDK — Write Minecraft Fabric Mods in C#</Title>
    <Description>Write Minecraft Fabric mods in C# instead of Java. Reference this package, write your mod logic using the CSCraft API, then run dotnet build — the transpiler converts your C# to Java, generates recipe JSON files automatically, and optionally runs Gradle to produce a ready-to-install .jar.

Supports: blocks (with mining categories and tool levels), items, armor, tools, food, events, commands, recipes (shaped, shapeless, smelting, blasting, smoking, campfire, stonecutting), auto-generated models/blockstates/lang/tag files, custom textures and sounds, entity tags, status effects, enchantments, particles, sounds, advancements, loot tables, villager trades, game rules, and more. JAR auto-copies to your project folder.

Target: Minecraft 1.21.1 · Fabric API 0.116.9+1.21.1 · Java 21</Description>
    <Authors>CSCraft</Authors>
    <PackageTags>minecraft;fabric;mod;transpiler;cscraft;java;modding;game</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/cscraft/cscraft</PackageProjectUrl>
    <RepositoryUrl>https://github.com/cscraft/cscraft</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>

    <PackageOutputPath>../nupkg</PackageOutputPath>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- Don't emit a lib DLL for this wrapper project itself -->
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoWarn>NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />

    <None Include="../CSharpStubs/bin/Release/net9.0/CSharpStubs.dll" Pack="true" PackagePath="lib/net9.0/" />

    <None Include="build/CSCraft.Sdk.props" Pack="true" PackagePath="build/" />
    <None Include="build/CSCraft.Sdk.targets" Pack="true" PackagePath="build/" />

    <None Include="build/tasks\**\*" Pack="true" PackagePath="build/tasks/" />

    <None Include="build/gradle-wrapper/gradlew" Pack="true" PackagePath="build/gradle-wrapper/" />
    <None Include="build/gradle-wrapper/gradlew.bat" Pack="true" PackagePath="build/gradle-wrapper/" />
    <None Include="build/gradle-wrapper/gradle/wrapper/gradle-wrapper.jar" Pack="true" PackagePath="build/gradle-wrapper/gradle/wrapper/" />
    <None Include="build/gradle-wrapper/gradle/wrapper/gradle-wrapper.properties" Pack="true" PackagePath="build/gradle-wrapper/gradle/wrapper/" />
  </ItemGroup>

</Project>